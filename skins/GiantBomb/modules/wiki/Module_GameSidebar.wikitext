-- game page sidebar: one smw query replaces the per-property #show storm.
-- accordions come ranked from gb_related, own smw values fill in pre-backfill
local p = {}

local smwData, store

local function fetch()
    if smwData == nil then
        local page = mw.title.getCurrentTitle().prefixedText
        local ok, res = pcall(mw.smw.ask, {
            '[[' .. page .. ']]',
            '?Has name=name',
            '?Has release date#ISO=released',
            '?Has release date type=datetype',
            '?Has platforms=platforms',
            '?Has developers=developers',
            '?Has publishers=publishers',
            '?Has genres=genres',
            '?Has themes=themes',
            '?Has franchises=franchises',
            '?Has aliases=aliases',
            '?Has characters=characters',
            '?Has locations=locations',
            '?Has concepts=concepts',
            '?Has objects=objects',
            '?Has similar games=similar',
            'mainlabel=-',
            'limit=1',
        })
        smwData = ok and type(res) == 'table' and res[1] or {}
        store = mw.ext.gbrelated.get() or {}
    end
    return smwData, store
end

-- single values arrive bare, multi values as a table -> always a table
local function values(v)
    if v == nil then
        return {}
    end
    if type(v) ~= 'table' then
        return { v }
    end
    return v
end

-- page-type values are wikitext links already; just join them
local function joinLinks(v, sep)
    local out = {}
    for _, item in ipairs(values(v)) do
        out[#out + 1] = tostring(item)
    end
    return table.concat(out, sep or ', ')
end

-- smw hands values back as wikitext links (with a leading colon) -> unwrap
local function plain(v)
    local inner = tostring(v):match('^%[%[(.-)%]%]$')
    if inner then
        inner = inner:match('^(.-)|') or inner
        return inner:gsub('^:', '')
    end
    return tostring(v)
end

-- the gb image server serves every upload in each rendition bucket ->
-- swap whatever is stored for the small one
local function logoUrl(image)
    image = tostring(image)
        :gsub('^Http', 'http')
        :gsub('%+', ' ')
        :gsub(' ', '%%20')
        :gsub('"', '')
    if image:sub(1, 4) ~= 'http' then
        return nil
    end
    return image:gsub('/a/uploads/[%w_]+/', '/a/uploads/scale_small/', 1)
end

-- one query for every listed company's logo: [title -> url]
local function fetchCompanyLogos(...)
    local titles, seen = {}, {}
    for _, list in ipairs({ ... }) do
        for _, link in ipairs(list) do
            local t = plain(link)
            if t ~= '' and not seen[t] then
                seen[t] = true
                titles[#titles + 1] = t
            end
        end
    end
    if #titles == 0 then
        return {}
    end
    local ok, res = pcall(mw.smw.ask, {
        '[[' .. table.concat(titles, '||') .. ']]',
        '?Has image=image',
        'mainlabel=page',
        'limit=' .. #titles,
    })
    local out = {}
    if ok and type(res) == 'table' then
        for _, r in ipairs(res) do
            local img = r.image
            if type(img) == 'table' then
                img = img[1]
            end
            local url = img and logoUrl(img)
            if url then
                out[plain(r.page)] = url
            end
        end
    end
    return out
end

local FALLBACK_LOGO =
    'https://www.giantbomb.com/a/uploads/original/11/110673/3026329-gb_default-16_9.png'

local function companyList(v, logos)
    local out = {}
    for _, link in ipairs(values(v)) do
        local title = plain(link)
        local url = logos[title] or FALLBACK_LOGO
        -- [pageUrl imageUrl] -> the parser wraps the external image in the
        -- link, so the thumbnail itself is clickable
        local thumb = url
        local t = mw.title.new(title)
        if t then
            thumb = '[' .. t:fullUrl() .. ' ' .. url .. ']'
        end
        out[#out + 1] = '<div class="gb-sidebar-company-tile">'
            .. '<span class="gb-sidebar-company-thumb">' .. thumb .. '</span>'
            .. '<span class="gb-sidebar-company-name">'
            .. tostring(link) .. '</span>'
            .. '</div>'
    end
    if #out == 0 then
        return ''
    end
    return '<div class="gb-sidebar-companies">' .. table.concat(out) .. '</div>'
end

function p.details(frame)
    local data = fetch()
    local html = {}
    local function row(label, content)
        if content and content ~= '' then
            html[#html + 1] = '<dt>' .. label .. '</dt><dd>'
                .. content .. '</dd>'
        end
    end

    local name = joinLinks(data.name)
    if name == '' then
        name = mw.title.getCurrentTitle().subpageText
    end
    row('Name', name)

    local released = tostring(values(data.released)[1] or '')
    if released ~= '' then
        row('Release Date', frame:expandTemplate{
            title = 'DateDisplay',
            args = {
                released,
                tostring(values(data.datetype)[1] or ''),
            },
        })
    end

    row('Platform', joinLinks(data.platforms, '<br/>'))

    local logos = fetchCompanyLogos(
        values(data.developers),
        values(data.publishers)
    )
    row('Developer', companyList(data.developers, logos))
    row('Publisher', companyList(data.publishers, logos))
    row('Genre', joinLinks(data.genres, '<br/>'))
    row('Theme', joinLinks(data.themes, '<br/>'))
    row('Franchise', joinLinks(data.franchises))
    row('Aliases', joinLinks(data.aliases))

    return '<dl class="gb-game-details">' .. table.concat(html) .. '</dl>'
end

local SECTIONS = {
    { key = 'characters', label = 'Characters' },
    { key = 'locations',  label = 'Locations' },
    { key = 'concepts',   label = 'Concepts' },
    { key = 'objects',    label = 'Objects' },
    { key = 'people',     label = 'People' },
}
local LIST_LIMIT = 20

local function listItems(rows, fallbackValues)
    local items = {}
    if rows and #rows > 0 then
        for i = 1, math.min(LIST_LIMIT, #rows) do
            items[#items + 1] = '<li>[[' .. rows[i].title .. '|'
                .. rows[i].display .. ']]</li>'
        end
    else
        for i, v in ipairs(values(fallbackValues)) do
            if i > LIST_LIMIT then
                break
            end
            items[#items + 1] = '<li>' .. tostring(v) .. '</li>'
        end
    end
    return items
end

local function accordion(label, items, open, moreHtml)
    local cls = open and 'gb-accordion gb-accordion--open' or 'gb-accordion'
    if #items == 0 then
        items = { '<li><em>None</em></li>' }
    end
    return '<div class="' .. cls .. '">'
        .. '<div class="gb-accordion-header">' .. label .. '</div>'
        .. '<ul class="gb-accordion-content">' .. table.concat(items)
        .. (moreHtml or '') .. '</ul></div>'
end

function p.accordions(frame)
    local data, related = fetch()
    local out = {}

    -- similar games first, mirroring the company sidebar's games lists
    local similar = listItems(related.similar, data.similar)
    if #similar > 0 then
        local more = '<li class="gb-sidebar-more">['
            .. mw.title.getCurrentTitle():canonicalUrl()
            .. '#SimilarGames view all →]</li>'
        out[#out + 1] = accordion('Similar Games', similar, true, more)
    end

    for i, s in ipairs(SECTIONS) do
        local items = listItems(related[s.key], data[s.key])
        out[#out + 1] = accordion(s.label, items, #out == 0 and i == 1)
    end

    return table.concat(out)
end

return p
