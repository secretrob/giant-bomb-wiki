local p = {}

local cachedReviews = nil

function p.fetchReviews(guid)
    if cachedReviews then 
        return cachedReviews 
    end

    if not guid or guid == '' then return {} end
    
    local baseUrl = "https://giantbomb.com/api/public/user-reviews"
    local allReviews = {}
    local offset = 0
    local limit = 20
    local hasNext = true
    
    while hasNext do
        local url = string.format(
            "%s?limit=%d&offset=%d&game_guid=%s&sort=publish_date:desc&format=json",
            baseUrl, limit, offset, guid
        )
    
        local values, errors = mw.ext.externalData.getExternalData({
            url = url,
            format = 'json'
        })
        
        local data = nil
        if values and values.__json then
            data = values.__json
        end

        if data and data.results then
            for _, review in ipairs(data.results) do
                table.insert(allReviews, review)
            end
            
            if data.pagination and data.pagination.has_next then
                offset = offset + limit
            else
                hasNext = false
            end
        else
            hasNext = false
        end
        
        if offset > 1000 then break end 
    end

    cachedReviews = allReviews
    return cachedReviews
end

function p._renderSidebar(guid, hideReadButton)

    local allReviews = p.fetchReviews(guid)

    local counts = { [5]=0, [4]=0, [3]=0, [2]=0, [1]=0 }
    local totalScore = 0
    local reviewCount = #allReviews

    for _, review in ipairs(allReviews) do
        local stars = math.floor(review.score / 20)
        if stars < 1 then stars = 1 end
        
        counts[stars] = counts[stars] + 1
        totalScore = totalScore + stars
    end

    local avgScore = reviewCount > 0 and (totalScore / reviewCount) or 0

    local currentPage = mw.title.getCurrentTitle().prefixedText
    local reviewsPage = currentPage:match('/Reviews$') and currentPage or (currentPage .. '/Reviews')

    local header = mw.html.create('div'):addClass('gb-sidebar-section-header')
        :wikitext('[[' .. reviewsPage .. '|What the users think]]')    
    
    local html = mw.html.create('div'):addClass('gb-sidebar-section-content')

    for i = 5, 1, -1 do
        local row = html:tag('div'):addClass('review-star-bar')
        row:tag('span'):wikitext(i .. ' ★ (' .. counts[i] .. ')')
        
        local barContainer = row:tag('div'):addClass('review-bar')
        local barWidth = reviewCount > 0 and (counts[i] / reviewCount * 100) or 0
        barContainer:tag('div'):addClass("review-fill"):css('width', barWidth .. '%')
    end

    local footer = html:tag('div'):addClass('gb-review-footer')
    local scoreColumn = footer:tag('div'):addClass('gb-review-score-column')

    local row = scoreColumn:tag('div'):addClass('gb-review-summary-row')
    row:tag('span'):addClass('gb-review-score-text')
        :wikitext('[[' .. reviewsPage .. '|' .. string.format("%.1f ", avgScore) .. ']]')

    local starScore = (avgScore / 5) * 100
    local starContainer = row:tag('div'):addClass('stars')
    for i = 5, 1, -1 do
        starContainer:tag('div'):addClass('star')
    end
    starContainer:tag('div'):addClass("star-cover"):css('width', starScore .. '%')

    scoreColumn:tag('div'):addClass('gb-review-subtext')
        :wikitext('[[' .. reviewsPage .. '|Average score of ' .. reviewCount .. ' user reviews]]')
    if not hideReadButton then
        footer:tag('div'):addClass('gb-review-button'):addClass('gb-review-button--primary'):addClass('gb-button'):wikitext('[[' .. reviewsPage .. '|Read reviews]]')
    end
    footer:tag('div'):addClass('gb-review-button'):addClass('gb-button'):wikitext('[https://giantbomb.com/user-reviews/new Add your review]')

    return tostring(header) .. tostring(html)
end

function p.renderSidebar(frame)
    local guid = frame.args.guid or frame:getParent().args.guid
    return p._renderSidebar(guid)
end

function p.renderReviewContent(frame)
    local guid = frame.args.guid or frame:getParent().args.guid
    local allReviews = p.fetchReviews(guid)

    if not allReviews or #allReviews == 0 then
        return "<p>No reviews found.</p>"
    end
    
    local output = {}
    table.insert(output, '<div class="gb-reviews-grid">')
    
    for _, review in ipairs(allReviews) do
        local reviewUrl = string.format("https://giantbomb.com/%s", 
            tostring(review.url)
        )

        table.insert(output, '<div class="user-review">')
        
        local titleEl = mw.html.create('h3'):addClass('user-review-title')
        titleEl:wikitext('[' .. reviewUrl .. ' ' .. review.title .. ']')
        table.insert(output, tostring(titleEl))
        
        local metaContainer = mw.html.create('div')
            :addClass('review-metadata')            

        if review.owner and review.owner.avatar and review.owner.avatar.url then
            local altText = review.owner.avatar.alt or (review.owner.username .. "'s avatar")
            metaContainer:tag('span')
                :addClass('user-avatar-frame')
                :wikitext(string.format("%s", review.owner.avatar.url))
        end

        local detailsStack = metaContainer:tag('div')
            :addClass('review-details-stack')
            
        local stars = math.floor(review.score / 20)
        if stars < 1 then stars = 1 end
        if stars > 5 then stars = 5 end
        
        local starPercentage = (stars / 5) * 100
        
        local starContainer = detailsStack:tag('div'):addClass('stars')
        for i = 1, 5 do
            starContainer:tag('div'):addClass('star')
        end
        starContainer:tag('div')
            :addClass("star-cover")
            :css('width', starPercentage .. '%')        

        local authorHtml = ""
        if review.owner and review.owner.username then             
            local userLink = "https://giantbomb.com/profile/" .. review.owner.username
            authorHtml = authorHtml .. " by " .. string.format("[%s %s]", userLink, review.owner.username) .. " on "
        end
        local date = mw.language.getContentLanguage():formatDate('F, j Y', review.publish_date)
        authorHtml = authorHtml .. date
        detailsStack:tag('span'):addClass('author-text'):wikitext(authorHtml)
            
        table.insert(output, tostring(metaContainer))
        
        local excerptContainer = mw.html.create('p')
            :addClass('review-excerpt')
            :wikitext(review.excerpt .. ' [' .. reviewUrl .. ' Read more]')
            
        table.insert(output, tostring(excerptContainer))
        table.insert(output, '</div>')
    end
    table.insert(output, '</div>')

    local sidebarHtml = p._renderSidebar(guid, true)
    
    table.insert(output, 1, sidebarHtml)
    table.insert(output, 2, "__NOTOC__")

    return table.concat(output, "\n")
end

return p
