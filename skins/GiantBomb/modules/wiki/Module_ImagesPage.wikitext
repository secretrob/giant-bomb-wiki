local p = {}

local entityConfig = {
    ["Games"]       = { label = "Game",       cssPrefix = "gb-game",       hasReviews = true,  sidebar = "GameSidebar" },
    ["Characters"]  = { label = "Character",  cssPrefix = "gb-character",  hasReviews = false, sidebar = "CharacterSidebar" },
    ["Companies"]   = { label = "Company",    cssPrefix = "gb-company",    hasReviews = false, sidebar = "CompanySidebar" },
    ["Concepts"]    = { label = "Concept",    cssPrefix = "gb-concept",    hasReviews = false, sidebar = "ConceptSidebar" },
    ["Franchises"]  = { label = "Franchise Wiki", cssPrefix = "gb-franchise", hasReviews = false, sidebar = "FranchiseSidebar" },
    ["Platforms"]   = { label = "Platform",   cssPrefix = "gb-platform",   hasReviews = false, sidebar = "PlatformSidebar" },
    ["People"]      = { label = "Person",     cssPrefix = "gb-person",     hasReviews = false, sidebar = "PersonSidebar" },
    ["Locations"]   = { label = "Location",   cssPrefix = "gb-location",   hasReviews = false, sidebar = "LocationSidebar" },
    ["Objects"]     = { label = "Object",     cssPrefix = "gb-object",     hasReviews = false, sidebar = "ObjectSidebar" },
    ["Genres"]      = { label = "Genre",      cssPrefix = "gb-genre",      hasReviews = false },
    ["Themes"]      = { label = "Theme",      cssPrefix = "gb-theme",      hasReviews = false },
    ["Accessories"] = { label = "Accessory",  cssPrefix = "gb-accessory",  hasReviews = false, sidebar = "AccessorySidebar" },
    ["DLCs"]        = { label = "DLC",        cssPrefix = "gb-dlc",        hasReviews = false },
    ["Releases"]    = { label = "Release",    cssPrefix = "gb-release",    hasReviews = false },
}

local function getEntityType(parentPage)
    local rootPrefix = parentPage:match("^([^/]+)/")
    if rootPrefix and entityConfig[rootPrefix] then
        return entityConfig[rootPrefix], rootPrefix
    end
    return nil, nil
end

local function queryParentProperties(parentPage)
    if not mw.smw then
        return {}
    end
    local result = mw.smw.ask({
        "[[" .. parentPage .. "]]",
        "?Has name=name",
        "?Has deck=deck",
        "?Has image=image",
        "?Has background image=backgroundImage",
        limit = 1,
        link = 'none'
    })
    if result and result[1] then
        return result[1]
    end
    return {}
end

function p.render(frame)
    local currentTitle = mw.title.getCurrentTitle()
    local fullPage = currentTitle.prefixedText
    local parentPage = fullPage:gsub("/Images$", "")
    local config, rootPrefix = getEntityType(parentPage)

    if not config then
        return '<div class="gb-images-page"><div class="gb-images-content"><div class="gb-images-main"><div class="gb-images-wiki-content">'
    end

    local props = queryParentProperties(parentPage)
    local name = props.name or parentPage:match("[^/]+$") or parentPage
    local deck = props.deck or ""
    local css = config.cssPrefix

    local coverImg = frame:callParserFunction('#show', parentPage, '?Has image', 'link=none')
    if coverImg == '' then coverImg = nil end

    local bgImg = frame:callParserFunction('#show', parentPage, '?Has background image', 'link=none')
    if bgImg == '' then bgImg = nil end

    local coverHtml = ""
    if coverImg then
        if coverImg:sub(1, 4) == "http" then
            coverHtml = '<div style="display:none;" id="coverImageData">' .. coverImg .. '</div>'
        else
            coverHtml = '<div style="display:none;" id="coverImageData">[[File:' .. coverImg .. '|300px|link=]]</div>'
        end
    end

    local backgroundHtml = ""
    if bgImg then
        if bgImg:sub(1, 4) == "http" then
            backgroundHtml = '<div style="display:none;" id="backgroundImageData">' .. bgImg .. '</div>'
        else
            backgroundHtml = '<div style="display:none;" id="backgroundImageData">[[File:' .. bgImg .. '|300px|link=]]</div>'
        end
    end

    local tabs = {}
    table.insert(tabs, '<span class="' .. css .. '-tabs-tab">[[' .. parentPage .. '|' .. config.label .. ']]</span>')
    table.insert(tabs, '<span class="' .. css .. '-tabs-tab ' .. css .. '-tabs-tab--active">Images</span>')
    if config.hasReviews then
        table.insert(tabs, '<span class="' .. css .. '-tabs-tab">[[' .. parentPage .. '/Reviews|Reviews]]</span>')
    end
    table.insert(tabs, '<span class="' .. css .. '-tabs-tab">[[Special:WhatLinksHere/' .. parentPage .. '|Related Pages]]</span>')

    local actions = '<div class="gb-wiki-actions">'
        .. '<span class="gb-wiki-action">[' .. tostring(mw.uri.fullUrl(fullPage, "action=edit")) .. ' Edit]</span>'
        .. '<span class="gb-wiki-action">[' .. tostring(mw.uri.fullUrl(fullPage, "action=history")) .. ' History]</span>'
        .. '</div>'

    local html = '<div class="' .. css .. '-page">'
        .. coverHtml
        .. backgroundHtml
        .. '<div class="' .. css .. '-hero">'
        .. '<div class="' .. css .. '-hero-container">'
        .. '<div class="' .. css .. '-hero-cover"></div>'
        .. '<div class="' .. css .. '-hero-info">'
        .. '<div class="' .. css .. '-hero-title">' .. mw.text.nowiki(name) .. '</div>'
        .. '<div class="' .. css .. '-hero-meta"><span class="' .. css .. '-hero-type">' .. string.upper(config.label) .. '</span> &#187; Images</div>'
        .. '<div class="' .. css .. '-hero-deck">' .. mw.text.nowiki(deck) .. '</div>'
        .. '</div>'
        .. '</div>'
        .. '</div>'
        .. '<div class="' .. css .. '-tabs">'
        .. '<div class="' .. css .. '-tabs-container">'
        .. '<div class="' .. css .. '-tabs-nav">'
        .. table.concat(tabs)
        .. '</div>'
        .. actions
        .. '</div>'
        .. '</div>'
        .. '<div class="' .. css .. '-content gb-images-content">'
        .. '<div class="' .. css .. '-main gb-images-main">'
        .. '<div class="' .. css .. '-wiki-content">'

    return frame:preprocess(html)
end

function p.close(frame)
    local currentTitle = mw.title.getCurrentTitle()
    local fullPage = currentTitle.prefixedText
    local parentPage = fullPage:gsub("/Images$", "")
    local config = getEntityType(parentPage)

    if not config or not config.sidebar then
        return '</div></div></div></div>'
    end

    local css = config.cssPrefix

    local function show(prop, opts)
        local val = frame:callParserFunction('#show', parentPage, '?' .. prop, opts or '')
        return val ~= '' and val or nil
    end

    local function showList(prop)
        return frame:callParserFunction('#show', parentPage, '?' .. prop, 'format=list', 'link=all', 'sep=<br/>', 'limit=50')
    end

    local parts = {}
    table.insert(parts, '<div class="gb-sidebar-section">')
    table.insert(parts, '<div class="gb-sidebar-section-header">Game details</div>')
    table.insert(parts, '<div class="gb-sidebar-section-content"><dl class="gb-game-details">')

    local name = show('Has name', 'link=none') or parentPage:match("[^/]+$") or parentPage
    local details = {
        { 'Name', name },
        { 'Platform', showList('Has platforms') },
        { 'Developer', showList('Has developers') },
        { 'Publisher', showList('Has publishers') },
        { 'Genre', showList('Has genres') },
        { 'Theme', showList('Has themes') },
    }
    for _, d in ipairs(details) do
        if d[2] and d[2] ~= '' then
            table.insert(parts, '<dt>' .. d[1] .. '</dt><dd>' .. d[2] .. '</dd>')
        end
    end

    table.insert(parts, '</dl></div></div>')

    return '</div></div>'
        .. '<div class="' .. css .. '-sidebar gb-images-sidebar">'
        .. table.concat(parts)
        .. '</div>'
        .. '</div></div>'
end

return p
