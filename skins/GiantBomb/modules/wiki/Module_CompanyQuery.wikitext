local p = {}

function p.render(frame)
    local args = frame.args
    local parentArgs = frame:getParent() and frame:getParent().args or {}
    local rawLetter = args.chosen_letter or parentArgs.chosen_letter or "All"
    local currentLetter = mw.uri.decode(rawLetter, "WIKI")
    local searchFilter = mw.uri.decode(args.search_filter or parentArgs.search_filter or "","QUERY")
    
    local sortFilter = mw.uri.decode(args.sort_by or parentArgs.sort_by or "", "WIKI"):lower()
    -- default: search -> relevance; otherwise oldest first (guid order)
    local relevanceMode = false
    local sortProp = "Creation date"
    local sortOrder = "ascending"

    if sortFilter == "newest" then
        sortProp = "Creation date"
        sortOrder = "descending"
    elseif sortFilter == "latest" then
        sortProp = "Modification date"
        sortOrder = "descending"
    elseif sortFilter == "name" then
        sortProp = "Has name"
        sortOrder = "ascending"
    elseif sortFilter == "" and searchFilter ~= "" then
        relevanceMode = true
    end

    local limit = tonumber(args.limit) or tonumber(parentArgs.limit) or 48
    local offset = tonumber(args.offset) or tonumber(parentArgs.offset) or 0
    
    if currentLetter:find('{{#urlget') then
        currentLetter = "All"
    end

    -- match in-query so limit caps matches, not the searched pool
    local query = "[[Category:Companies]] "
    if searchFilter ~= "" then
        local term = searchFilter:gsub("[%[%]|<>]", "")
        query = query .. "[[Has name::~" .. term .. "*]] "
    end
    
    if currentLetter ~= "All" then
        if currentLetter == "#" then
            query = query .. " [[Has name::~[0-9]*]]"
        else
            query = query .. " [[Has name::~" .. currentLetter .. "*]]"
        end
    end

    local RELEVANCE_CAP = 500
    local cardPrintouts = {
        "?Has image",
        "?Has deck",
        "?Modification date",
        "?Creation date",
    }

    local queryData, results
    if relevanceMode then
        -- phase 1: names only -- card printouts for 500 matches was a 504
        local matches = mw.smw.getQueryResult({
            query,
            limit = RELEVANCE_CAP,
            ["count"] = true,
        })
        if not matches or not matches.results or #matches.results == 0 then
            return '<div class="no-results">No companies found for "'
                .. searchFilter .. '"</div>'
        end

        -- exact name > prefix > word start > substring; short names win ties
        local term = searchFilter:lower()
        local function relevance(r)
            local name = (r.fulltext or ""):gsub("^[^/]*/", ""):lower()
            if name == term then
                return 0
            end
            local s = name:find(term, 1, true)
            if s == 1 then
                return 1
            end
            if s and name:sub(s - 1, s - 1):match("[%s%-/(:.]") then
                return 2
            end
            return s and 3 or 4
        end
        local scores, names = {}, {}
        for _, r in ipairs(matches.results) do
            scores[r] = relevance(r)
            names[r] = (r.fulltext or ""):lower()
        end
        table.sort(matches.results, function(a, b)
            if scores[a] ~= scores[b] then
                return scores[a] < scores[b]
            end
            if #names[a] ~= #names[b] then
                return #names[a] < #names[b]
            end
            return names[a] < names[b]
        end)

        -- phase 2: card data for just the visible page
        local rank, disjuncts = {}, {}
        for i = offset + 1, math.min(offset + limit, #matches.results) do
            local title = matches.results[i].fulltext or ""
            rank[title] = i
            disjuncts[#disjuncts + 1] = title
        end
        if #disjuncts == 0 then
            return '<div class="no-results">No companies found for "'
                .. searchFilter .. '"</div>'
        end
        local cardQuery = { "[[" .. table.concat(disjuncts, "||") .. "]]" }
        for _, po in ipairs(cardPrintouts) do
            cardQuery[#cardQuery + 1] = po
        end
        cardQuery.limit = #disjuncts
        queryData = mw.smw.getQueryResult(cardQuery)
        queryData.count = matches.count

        results = queryData.results or {}
        table.sort(results, function(a, b)
            return (rank[a.fulltext or ""] or 999) < (rank[b.fulltext or ""] or 999)
        end)
    else
        local storeQuery = { query }
        for _, po in ipairs(cardPrintouts) do
            storeQuery[#storeQuery + 1] = po
        end
        storeQuery.limit = limit
        storeQuery.offset = offset
        storeQuery["count"] = true
        storeQuery.sort = sortProp
        storeQuery.order = sortOrder
        queryData = mw.smw.getQueryResult(storeQuery)

        if not queryData or not queryData.results or #queryData.results == 0 then
            local what = searchFilter ~= "" and ('"' .. searchFilter .. '"')
                or currentLetter
            return '<div class="no-results">No companies found for '
                .. what .. '</div>'
        end
        results = queryData.results
    end

    local html = mw.html.create('div'):addClass('listing-grid')
    
    for _, result in ipairs(results) do
  	    local fullTitle = result.fulltext or ""
    	local cleanTitle = fullTitle:gsub("^[Cc][Oo][Mm][Pp][Aa][Nn][Ii][Ee][Ss]/", "")

        local function getSafe(field, isList)
            local d = result.printouts[field] or {}
            local vals = {}
            for _, v in ipairs(d) do
                local str = type(v) == "table" and (v.raw or v.fulltext or "") or tostring(v)
                table.insert(vals, str)
            end
            return isList and table.concat(vals, ", ") or (vals[1] or "")
        end

        local imageData = getSafe('Has image', false)
        imageData = imageData:gsub("Http", "http"):gsub("+", " "):gsub(" ", "%%20")

		html:wikitext(frame:expandTemplate{ 
		    title = 'CompanyCard', 
		    args = {
		        url_title    = fullTitle,
		        title        = cleanTitle,
		        deck         = getSafe('Has deck', true),
		        image        = imageData
		    }
		})
    end
    
    local totalResults = queryData.count or 0

	if totalResults == 0 and #queryData.results > 0 then
	    local countQuery = mw.smw.ask({ query, format = "count" })
	    totalResults = tonumber(countQuery) or 0
	end
	-- can't paginate past the capped fetch
	if relevanceMode then
	    totalResults = math.min(totalResults, RELEVANCE_CAP)
	end

	local paginationHtml = ""
	if totalResults > 0 then
	    paginationHtml = tostring(mw.html.create('div')
	        :addClass('pagination-wrapper')
	        :attr('data-total', totalResults)
	        :attr('data-limit', limit)
	        :attr('data-offset', offset)
	        :attr('data-letter', currentLetter)
	        :attr('data-search', searchFilter)
	        :attr('data-sort', sortFilter))
	end
	
	return tostring(html) .. paginationHtml
end

return p
