-- renders precomputed related content (gb_related table via mw.ext.gbrelated,
-- maintained by the GBRelated save hook + rebuildRelated.php backfill)
local p = {}

local cache

local function fetch()
    if cache == nil then
        cache = mw.ext.gbrelated.get() or {}
    end
    return cache
end

-- {{#invoke:CompanyGames|related|developed|limit=20|default=None}}
function p.related(frame)
    local args = frame.args
    local fallback = '<li><em>' .. (args.default or 'None') .. '</em></li>'
    -- positional #invoke args arrive untrimmed
    local group = mw.text.trim(args[1] or '')
    local rows = fetch()[group]
    if not rows or #rows == 0 then
        return fallback
    end
    local items = {}
    for i = 1, math.min(tonumber(args.limit) or 20, #rows) do
        local row = rows[i]
        items[#items + 1] =
            '<li>[[' .. row.title .. '|' .. row.display .. ']]</li>'
    end
    return table.concat(items)
end

-- smw hands values back as wikitext links (with a leading colon) -> unwrap
local function plain(v)
    local inner = tostring(v):match('^%[%[(.-)%]%]$')
    if inner then
        inner = inner:match('^(.-)|') or inner
        return inner:gsub('^:', '')
    end
    return tostring(v)
end

local function joinValues(v)
    if type(v) ~= 'table' then
        return v and plain(v) or ''
    end
    local out = {}
    for _, item in ipairs(v) do
        out[#out + 1] = plain(item)
    end
    return table.concat(out, ', ')
end

-- {{#invoke:CompanyGames|cards|developed|limit=12}}
function p.cards(frame)
    local args = frame.args
    local group = mw.text.trim(args[1] or '')
    local rows = fetch()[group]
    if not rows or #rows == 0 then
        return '<div class="no-results">No games found</div>'
    end

    local limit = math.min(tonumber(args.limit) or 12, #rows)
    local titles, rank = {}, {}
    for i = 1, limit do
        titles[#titles + 1] = rows[i].title
        rank[rows[i].title] = i
    end

    -- links stay on: with link=none smw captions the mainlabel with the
    -- display title, which breaks keying by page title
    local results = mw.smw.ask{
        '[[' .. table.concat(titles, '||') .. ']]',
        '?Has deck=deck',
        '?Has image=image',
        '?Has platforms=platforms',
        '?Has release date=released',
        'mainlabel=page',
        'limit=' .. limit,
    } or {}

    local byTitle = {}
    for _, r in ipairs(results) do
        byTitle[plain(r.page)] = r
    end

    local html = mw.html.create('div'):addClass('listing-grid')
    for i = 1, limit do
        local title = titles[i]
        local r = byTitle[title] or {}

        local image = plain(r.image or '')
        image = image:gsub('Http', 'http'):gsub('%+', ' '):gsub(' ', '%%20')

        local released = r.released
        if type(released) == 'table' then
            released = released.raw or released[1] or ''
        end
        released = tostring(released or '')
        local y, m, d = released:match('^1/(%d+)/(%d+)/(%d+)')
        if y then
            released = mw.language.getContentLanguage():formatDate(
                'Y F j',
                string.format('%04d-%02d-%02d', y, m, d)
            )
        end

        html:wikitext(frame:expandTemplate{
            title = 'GameCard',
            args = {
                url_title = title,
                title = rows[i].display,
                platforms = joinValues(r.platforms),
                release_date = released ~= '' and released or nil,
                deck = joinValues(r.deck),
                image = image,
            },
        })
    end
    return tostring(html)
end

return p
