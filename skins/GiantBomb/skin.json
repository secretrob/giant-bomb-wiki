{
  "name": "GiantBomb",
  "author": "Giant Bomb Wiki Street Team",
  "url": "https://www.giantbomb.com/",
  "description": "A custom MediaWiki skin for the Giant Bomb Wiki.",
  "license-name": "MIT",
  "type": "skin",
  "Hooks": {
    "ParserAfterTidy": "SkinGiantBomb::onParserAfterTidy",
    "BeforePageDisplay": "SkinGiantBomb::onBeforePageDisplay",
    "OutputPageBodyAttributes": "SkinGiantBomb::onOutputPageBodyAttributes"
  },
  "ValidSkinNames": {
    "giantbomb": {
      "class": "SkinGiantBomb",
      "args": [
        {
          "name": "giantbomb",
          "template": "GiantBombTemplate",
          "styles": ["skins.giantbomb"]
        }
      ]
    }
  },
  "AutoloadClasses": {
    "SkinGiantBomb": "includes/SkinGiantBomb.php",
    "GiantBombTemplate": "includes/GiantBombTemplate.php",
    "GiantBomb\\Skin\\Helpers\\PageHelper": "includes/helpers/PageHelper.php"
  },
  "ResourceModules": {
    "skins.giantbomb.styles": {
      "styles": [
        "resources/css/accessory-wiki.css",
        "resources/css/character-wiki.css",
        "resources/css/company-wiki.css",
        "resources/css/concept-wiki.css",
        "resources/css/dlc-wiki.css",
        "resources/css/editor.css",
        "resources/css/filters.css",
        "resources/css/franchise-wiki.css",
        "resources/css/game-wiki.css",
        "resources/css/gamePage.css",
        "resources/css/gamerating-wiki.css",
        "resources/css/genre-wiki.css",
        "resources/css/landingPage.css",
        "resources/css/listingPage.css",
        "resources/css/location-wiki.css",
        "resources/css/newReleasesPage.css",
        "resources/css/object-wiki.css",
        "resources/css/pageWrapper.css",
        "resources/css/pagination.css",
        "resources/css/person-wiki.css",
        "resources/css/platform-wiki.css",
        "resources/css/ratingboard-wiki.css",
        "resources/css/region-wiki.css",
        "resources/css/release-wiki.css",
        "resources/css/reviews.css",
        "resources/css/search.css",
        "resources/css/styles.css",
        "resources/css/theme-wiki.css",
        "resources/css/wikiNav.css"
      ]
    },
    "skins.giantbomb.wikijs": {
      "scripts": [
        "resources/js/search.js",
        "resources/js/game-sidebar-tabs.js",
        "resources/js/root-page-filters.js",
        "resources/js/wikieditor-link-dialog.js"
      ],
      "position": "top"
    }
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteSkinPath": "GiantBomb"
  },
  "manifest_version": 2
}
