<noinclude>
This is the "Game" form.
To create a page with this form, enter the page name below;
if a page with that name already exists, you will be sent to a form to edit that page.

{{#forminput:form=Game|super_page=Games}}

</noinclude><includeonly>
<div id="wikiPreview" style="display: none; padding-bottom: 25px; margin-bottom: 25px; border-bottom: 1px solid #AAAAAA;"></div>
{{{for template|Game}}}{{{field|Guid|property=Has guid|default=uuid|hidden|restricted}}}
{| class="formtable"
|-
! Name: 
| {{{field|Name|mandatory|property=Has name}}}
|-
! Aliases: 
| {{{field|Aliases|property=Has aliases}}}
|-
! Image: 
| {{{field|Image|uploadable|image preview|property=Has image}}}
|-
! BackgroundImage: 
| {{{field|BackgroundImage|uploadable|image preview|property=Has background image}}}
|-
! Caption: 
| {{{field|Caption|property=Has caption}}}
|-
! Deck: 
| {{{field|Deck|property=Has deck}}}
|}
{{#if: {{#invoke:DateHelper|displayLegacyWarning}} |
<div id="legacy-warning" style="background-color: #fff3cd; border: 1px solid #ffeeba; color: #856404; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
  '''Legacy Release Date Detected:''' This page uses an old date setting (current value: {{#invoke:DateHelper|getExistingValue|ReleaseDate}}).<br/>
  Please select a release date type and fill in the fields below.<br/>
  ''Note: Saving this form without making a change will delete the release date.''
</div>
}}
{| class="formtable"
! style="width: 150px;" | Release Date Type: 
| {{{field|ReleaseDateType|property=Has release date type|input type=dropdown|mandatory|show on select=None=>default;Full=>full_date;Month=>month_year;Quarter=>quarter_year;Year=>only_year|default=Full}}}
|}
<div id="default">
</div>
<div id="full_date">
{| class="formtable"
! style="width: 150px;" | Release Date: 
| {{{field|ReleaseDate|input type=datepicker}}}
|}
</div>
<div id="month_year">
{| class="formtable"
! style="width: 150px;" | Release Month: 
| {{{field|MonthPart|input type=dropdown|values=January,February,March,April,May,June,July,August,September,October,November,December}}} {{{field|MonthYearPart|input type=year}}}
|}
</div>
<div id="quarter_year">
{| class="formtable"
! style="width: 150px;" | Release Quarter: 
| {{{field|QuarterPart|input type=dropdown|values=Q1,Q2,Q3,Q4}}} {{{field|QuarterYearPart|input type=year}}}
|}
</div>
<div id="only_year">
{| class="formtable"
! style="width: 150px;" | Release Year:
| {{{field|YearPart|input type=year}}}
|}
</div>
{| class="formtable"
! Characters:
| {{{field|Characters|property=Has characters|input type=tokens|values from category=Characters|existing values only}}}
|-
! Concepts:
| {{{field|Concepts|property=Has concepts|input type=tokens|values from category=Concepts|existing values only}}}
|-
! Developers:
| {{{field|Developers|property=Has developers|input type=tokens|values from category=Companies|existing values only}}}
|-
! Franchises:
| {{{field|Franchises|property=Has franchises|input type=tokens|values from category=Franchises|existing values only}}}
|-
! Genres:
| {{{field|Genres|property=Has genres|input type=tokens|values from category=Genres|existing values only}}}
|-
! Locations:
| {{{field|Locations|property=Has locations|input type=tokens|values from category=Locations|existing values only}}}
|-
! Objects:
| {{{field|Objects|property=Has objects|input type=tokens|values from category=Objects|existing values only}}}
|-
! Platforms:
| {{{field|Platforms|property=Has platforms|input type=tokens|values from category=Platforms|existing values only}}}
|-
! Publishers:
| {{{field|Publishers|property=Has publishers|input type=tokens|values from category=Companies|existing values only}}}
|-
! Games:
| {{{field|Games|property=Has similar games|input type=tokens|values from category=Games|existing values only}}}
|-
! Themes:
| {{{field|Themes|property=Has themes|input type=tokens|values from category=Themes|existing values only}}}
|}
{{{end template}}}

