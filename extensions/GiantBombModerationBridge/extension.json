{
  "name": "GiantBombModerationBridge",
  "version": "1.3.5",
  "manifest_version": 2,
  "author": "Rob W.",
  "description": "Bridges Moderation and Page Forms by returning queued filenames to the form.",
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\GiantBombModerationBridge\\": "src/"
  },
  "ResourceModules": {
    "ext.GiantBombModerationBridge.js": {
      "scripts": ["modules/bridge.js"],
      "targets": ["desktop", "mobile"],
      "localBasePath": "",
      "remoteExtPath": "GiantBombModerationBridge"
    }
  },
  "Hooks": {
    "BeforePageDisplay": "BridgeHandler"
  },
  "HookHandlers": {
    "BridgeHandler": {
      "class": "MediaWiki\\Extension\\GiantBombModerationBridge\\HookHandler"
    }
  }
}
